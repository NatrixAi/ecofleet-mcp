# EcoFleet MCP — переменные окружения
# Копируй этот файл в .env и заполни свои значения
# Или вставляй напрямую в claude_desktop_config.json в секцию "env"

# API ключ EcoFleet (обязательно)
# Где взять: app.ecofleet.com → Профиль → Settings → API key
ECOFLEET_API_KEY=ВАШ_API_КЛЮЧ_ЗДЕСЬ

# Базовый URL API (не менять без причины)
# ВАЖНО: без /services на конце — только /seeme
ECOFLEET_BASE_URL=https://app.ecofleet.com/seeme
